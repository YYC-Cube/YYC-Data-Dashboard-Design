# ============================================
# YYC³ Data Dashboard Environment Configuration
# 本地多端推理矩阵数据库数据看盘前端
# ============================================

# Database Configuration / 数据库配置
# 本地 PostgreSQL 15 数据库 (yyc3_aify 仓库)
DATABASE_URL=postgresql://yyc3:your_password_here@localhost:5433/yyc3_aify
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=yyc3_aify
DATABASE_USER=yyc3
DATABASE_PASSWORD=your_password_here
DATABASE_SSL=false

# WebSocket Configuration / WebSocket 配置
# 实时数据推送服务
WEBSOCKET_URL=ws://localhost:3113/ws
WEBSOCKET_RECONNECT_INTERVAL=5000
WEBSOCKET_MAX_RECONNECT_ATTEMPTS=5

# Application Configuration / 应用配置
PORT=3118
NODE_ENV=development
BASE_URL=http://localhost:3118
API_BASE_URL=http://localhost:3210

# OpenAI API Configuration / OpenAI API 配置
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Local AI Models / 本地 AI 模型配置
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=codegeex4:9b
LOCAL_MODEL_ENABLED=true

# PWA Configuration / PWA 配置
PWA_ENABLED=true
PWA_CACHE_STRATEGY=networkFirst
PWA_OFFLINE_ENABLED=true

# NAS Configuration / NAS 配置
NAS_URL=http://192.168.3.45:9898
NAS_USER=yyc3
NAS_PASSWORD=your_nas_password_here

# Network Configuration / 网络配置
LOCAL_IP=192.168.3.x
WIFI_SSID=YYC3-Local-Network
LAN_ENABLED=true

# Security Configuration / 安全配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:3118

# Logging Configuration / 日志配置
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs

# Monitoring Configuration / 监控配置
MONITORING_ENABLED=true
METRICS_ENDPOINT=http://localhost:3113/metrics
HEALTH_CHECK_INTERVAL=30000

# Feature Flags / 功能开关
WEBSOCKET_ENABLED=true
LOCAL_STORAGE_ENABLED=true
OFFLINE_MODE_ENABLED=false
DEBUG_MODE=false

# Third-party Services / 第三方服务
SENTRY_DSN=https://your_sentry_dsn_here
ANALYTICS_ENABLED=false

# Storage Configuration / 存储配置
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/png,image/jpeg,image/svg+xml

# Performance Configuration / 性能配置
CACHE_ENABLED=true
CACHE_TTL=3600000
CONNECTION_POOL_SIZE=10

# Development Configuration / 开发配置
VITE_DEV_SERVER_PORT=3118
VITE_HMR_PORT=24678
VITE_DEV_HOST=localhost
